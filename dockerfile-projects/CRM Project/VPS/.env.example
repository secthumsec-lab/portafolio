# ============================================
# CONFIGURACIÓN DE SUITECRM
# ============================================
# Copia este archivo a .env y configura los valores
# cp .env.example .env

# ============================================
# MYSQL - Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=change_this_secure_password_123
MYSQL_DATABASE=suitecrm_db
MYSQL_USER=suitecrm_user
MYSQL_PASSWORD=change_this_user_password_456

# ============================================
# SuiteCRM - Admin Account
# ============================================
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_admin_password_789

# ============================================
# SuiteCRM - Support User (Optional)
# ============================================
SUPPORT_USER=support
SUPPORT_PASSWORD=change_this_support_password_111

# ============================================
# SuiteCRM - Client User (Optional)
# ============================================
CLIENT_USER=cliente
CLIENT_PASSWORD=change_this_client_password_222

# ============================================
# TIMEZONE
# ============================================
TZ=America/Mexico_City

# ============================================
# ENVIRONMENT
# ============================================
APP_ENV=production
DEBUG=false
