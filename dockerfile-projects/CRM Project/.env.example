# ============================================
# CONFIGURACIÓN DE SUITECRM
# ============================================
# Copia este archivo a .env y configura los valores
# cp .env.example .env
#
# IMPORTANTE: Las contraseñas deben coincidir con los archivos en secrets/
# Los archivos secrets/ contienen las contraseñas reales usadas por Docker

# ============================================
# MYSQL - Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=SuiteCRM_Root_2024!
MYSQL_DATABASE=crm
MYSQL_USER=crmuser
MYSQL_PASSWORD=SuiteCRM_User_2024!

# ============================================
# SuiteCRM - Installation Parameters
# ============================================
SUITE_URL=http://localhost:8080
SUITE_ADMIN_USER=admin
SUITE_ADMIN_PASSWORD=admin123
SUITE_DB_HOST=suitecrm_db
SUITE_DB_NAME=crm
SUITE_DB_USER=crmuser
SUITE_DB_PASSWORD=SuiteCRM_User_2024!
SUITE_DB_TYPE=mysql
SUITE_DB_PORT=3306
SUITE_DEMO_DATA=no
SUITE_SITE_NAME="CRM Project SuiteCRM"
SUITE_EMAIL=

# ============================================
# SuiteCRM - Legacy Users (Optional - for compatibility)
# ============================================
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
SUPPORT_USER=soporte
SUPPORT_PASSWORD=soporte123
CLIENT_USER=cliente
CLIENT_PASSWORD=cliente123

# ============================================
# TIMEZONE
# ============================================
TZ=America/Mexico_City

# ============================================
# ENVIRONMENT
# ============================================
APP_ENV=production
DEBUG=false
